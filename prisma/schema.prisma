generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ActivationCodeStatus {
  unused
  reserved
  used
  expired
  disabled
}

enum ActivationCodeKind {
  us
  uk
}

enum SmsSessionStatus {
  pending
  number_acquired
  waiting_sms
  code_received
  timeout
  failed
  cancelled
}

enum AdminRole {
  super_admin
  operator
}

enum PaymentOrderStatus {
  pending
  delivered
  expired
  cancelled
}

model Product {
  id          String             @id @default(cuid())
  slug        String             @unique @db.VarChar(60)
  name        String             @db.VarChar(80)
  description String?            @db.VarChar(160)
  kind        ActivationCodeKind
  amountFen   Int
  sortOrder   Int                @default(0)
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([isActive, sortOrder, createdAt])
  @@index([kind, isActive, sortOrder, createdAt])
}

model ActivationCode {
  id               String               @id @default(cuid())
  code             String               @unique @db.VarChar(14)
  kind             ActivationCodeKind   @default(us)
  status           ActivationCodeStatus @default(unused)
  expiresAt        DateTime?
  reservedAt       DateTime?
  usedAt           DateTime?
  lastUsedAt       DateTime?
  reservedByIp     String?              @db.VarChar(64)
  usageCount       Int                  @default(0)
  note             String?              @db.VarChar(120)
  createdByAdminId String?
  issuedPaymentOrderId String?          @unique
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  sessions         SmsSession[]
  issuedPaymentOrder PaymentOrder?      @relation("PaymentOrderIssuedCode", fields: [issuedPaymentOrderId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([kind, status, createdAt])
  @@index([expiresAt])
}

model SmsSession {
  id                   String           @id @default(cuid())
  activationCodeId     String
  providerName         String           @default("herosms")
  providerActivationId String?          @unique
  phoneNumber          String?          @db.VarChar(32)
  status               SmsSessionStatus @default(pending)
  timeoutAt            DateTime
  startedAt            DateTime?
  numberAcquiredAt     DateTime?
  numberChangeCount    Int              @default(0)
  completedAt          DateTime?
  cancelledAt          DateTime?
  lastPolledAt         DateTime?
  webhookReceivedAt    DateTime?
  pollAttempts         Int              @default(0)
  verificationCode     String?          @db.VarChar(16)
  verificationText     String?          @db.Text
  failureReason        String?          @db.VarChar(120)
  userIp               String?          @db.VarChar(64)
  metadata             Json?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  activationCode       ActivationCode   @relation(fields: [activationCodeId], references: [id], onDelete: Restrict)
  messages             SmsMessage[]

  @@index([status, createdAt])
  @@index([activationCodeId])
  @@index([phoneNumber])
}

model SmsMessage {
  id                String     @id @default(cuid())
  sessionId         String
  providerMessageId String?    @unique
  text              String     @db.Text
  code              String?    @db.VarChar(16)
  rawPayload        Json?
  receivedAt        DateTime?
  createdAt         DateTime   @default(now())
  session           SmsSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique @db.VarChar(120)
  passwordHash String    @db.VarChar(255)
  name         String?   @db.VarChar(80)
  role         AdminRole @default(operator)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model PaymentOrder {
  id             String             @id @default(cuid())
  orderNo        String             @unique @db.VarChar(24)
  kind           ActivationCodeKind
  amountFen      Int
  currency       String             @default("CNY") @db.VarChar(8)
  status         PaymentOrderStatus @default(pending)
  paymentChannel String?            @db.VarChar(40)
  userIp         String?            @db.VarChar(64)
  expiresAt      DateTime
  paidAt         DateTime?
  deliveredAt    DateTime?
  activationCodeDismissedAt DateTime?
  cancelledAt    DateTime?
  providerTradeNo String?           @db.VarChar(120)
  note           String?            @db.VarChar(120)
  metadata       Json?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  activationCode ActivationCode?    @relation("PaymentOrderIssuedCode")

  @@index([status, createdAt])
  @@index([kind, status, createdAt])
  @@index([expiresAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorType  String   @db.VarChar(20)
  actorId    String?  @db.VarChar(64)
  action     String   @db.VarChar(80)
  entityType String   @db.VarChar(40)
  entityId   String   @db.VarChar(64)
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([actorType, actorId, createdAt])
}
